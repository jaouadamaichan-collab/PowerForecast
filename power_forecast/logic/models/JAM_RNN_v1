def get_folds(df: pd.DataFrame, fold_length: int, fold_stride: int) -> List[pd.DataFrame]:
    """
    Parcourt un DataFrame de série temporelle pour en extraire des folds de longueur fixe.

    La fenêtre avance de `fold_stride` lignes à chaque itération.
    Toute fenêtre qui dépasserait la fin du DataFrame est ignorée.

    Args:
        df (pd.DataFrame): Le DataFrame complet, de forme (n_pas, n_features).
        fold_length (int): Nombre de pas de temps dans chaque fold.
        fold_stride (int): Nombre de pas à avancer entre deux folds.

    Returns:
        List[pd.DataFrame]: Liste de DataFrames, chacun représentant un fold.
    """
    folds = []
    for idx in range(0, len(df), fold_stride):
        if (idx + fold_length) > len(df):
            break
        folds.append(df.iloc[idx:idx + fold_length, :])
    return folds


def train_test_split(fold: pd.DataFrame, train_test_ratio: float,
                     input_length: int) -> Tuple[pd.DataFrame]:
    """
    Divise un fold en ensemble d'entraînement et de test.

    Le test commence `input_length` lignes avant la fin du train pour garantir
    une première fenêtre d'entrée complète (chevauchement intentionnel).

    Args:
        fold (pd.DataFrame): Fold de pas de temps.
        train_test_ratio (float): Proportion allouée à l'entraînement.
        input_length (int): Longueur de chaque séquence X_i.

    Returns:
        Tuple[pd.DataFrame]: (fold_train, fold_test)
    """
    last_train_idx  = round(train_test_ratio * len(fold))
    fold_train      = fold.iloc[0:last_train_idx, :]
    first_test_idx  = last_train_idx - input_length
    fold_test       = fold.iloc[first_test_idx:, :]
    return (fold_train, fold_test)


# GAP de 24h entre la fin de X_i et le début de y_i (prévision day-ahead)
DAY_AHEAD_GAP = 24


def get_X_y_strides(fold: pd.DataFrame, input_length: int, output_length: int,
                    sequence_stride: int) -> Tuple[np.array]:
    """
    Construit un jeu de données en faisant glisser une fenêtre à pas fixe sur le fold.

    Un décalage de 24h (DAY_AHEAD_GAP) est appliqué entre la fin de X_i et le début
    de y_i, conformément à l'objectif métier de prévision day-ahead :
    "connaissant les données jusqu'à t, prédire la consommation à t+24h."

    Schéma temporel :
        [--- X_i (input_length) ---][--- gap 24h ---][y_i]

    Args:
        fold (pd.DataFrame): Fold de la série temporelle.
        input_length (int): Longueur de chaque fenêtre X_i.
        output_length (int): Longueur de chaque cible y_i.
        sequence_stride (int): Pas entre le début de deux séquences consécutives.

    Returns:
        Tuple[np.array]: (X, y) avec X de forme (n_seq, input_length, n_features)
    """
    X, y = [], []
    for i in range(0, len(fold), sequence_stride):
        # On s'arrête si la fenêtre complète (X + gap + y) dépasse la longueur du fold
        if (i + input_length + DAY_AHEAD_GAP + output_length) > len(fold):
            break
        X.append(fold.iloc[i:i + input_length, :])
        # La cible est décalée de 24h après la fin de X_i
        y_start = i + input_length + DAY_AHEAD_GAP
        y.append(fold.iloc[y_start:y_start + output_length, :][[TARGET]])
    return (np.array(X), np.array(y))


# ================================================================= #
# 6. MODÈLE LSTM OPTIMISÉ                                           #
# ================================================================= #

def init_model(X_train: np.array, y_train: np.array) -> tf.keras.Model:
    """
    Construit et compile le modèle LSTM optimisé.

    Améliorations par rapport à la version initiale :

    Architecture :
        - 2 couches LSTM empilées (128 + 64 unités) au lieu d'une seule.
          La première couche (return_sequences=True) passe toute la séquence
          à la deuxième, qui en extrait un résumé final.
        - Dropout(0.2) après chaque LSTM pour limiter l'overfitting.
        - Dense(32) intermédiaire avec activation ReLU avant la sortie,
          pour une meilleure capacité de projection non-linéaire.
        - Régularisation L1L2 allégée (0.01) car le Dropout est déjà actif.

    Compilation :
        - Loss : MSE
        - Optimiseur : Adam (lr initial = 0.001)
        - Métrique : MAE

    Args:
        X_train (np.array): Entrées d'entraînement (n_samples, input_length, n_features).
        y_train (np.array): Cibles d'entraînement (n_samples, output_length, 1).

    Returns:
        tf.keras.Model: Modèle Keras compilé.
    """
    # Normalisation adaptée sur les données d'entraînement
    normalizer = Normalization()
    normalizer.adapt(X_train)

    model = models.Sequential([
        Input(shape=X_train[0].shape),
        normalizer,

        # --- Couche LSTM 1 : extrait des patterns de bas niveau ---
        # return_sequences=True : on passe toute la séquence à la couche suivante
        layers.LSTM(
            128,
            activation='tanh',
            return_sequences=True,
            kernel_regularizer=L1L2(l1=0.01, l2=0.01)
        ),
        layers.Dropout(0.2),   # Désactive 20% des neurones aléatoirement à chaque batch

        # --- Couche LSTM 2 : capture des dépendances de plus haut niveau ---
        layers.LSTM(
            64,
            activation='tanh',
            return_sequences=False,
            kernel_regularizer=L1L2(l1=0.01, l2=0.01)
        ),
        layers.Dropout(0.2),

        # --- Couche Dense intermédiaire : projection non-linéaire ---
        layers.Dense(32, activation='relu'),

        # --- Sortie linéaire pour la régression ---
        layers.Dense(y_train.shape[1], activation='linear'),
    ])

    model.compile(
        loss='mse',
        optimizer=optimizers.Adam(learning_rate=0.001),
        metrics=["mae"]
    )
    return model


# ================================================================= #
# 5. ENTRAÎNEMENT OPTIMISÉ                                          #
# ================================================================= #

def fit_model(model: tf.keras.Model, X_train: np.array, y_train: np.array,
              verbose: int = 1) -> Tuple[tf.keras.Model, tf.keras.callbacks.History]:
    """
    Entraîne le modèle avec early stopping et réduction adaptative du learning rate.

    Améliorations par rapport à la version initiale :

        - ReduceLROnPlateau : divise lr par 2 si val_loss ne s'améliore pas pendant
          5 époques. Permet un affinement progressif sans fixer un lr trop bas dès le départ.
        - Early stopping avec patience=15 (au lieu de 10) pour laisser au scheduler
          le temps de réduire le lr avant d'arrêter.
        - 100 époques max (au lieu de 50).
        - Batch size réduit à 16 pour des gradients plus informatifs.

    Args:
        model (tf.keras.Model): Modèle Keras compilé.
        X_train (np.array): Données d'entrée d'entraînement.
        y_train (np.array): Cibles d'entraînement.
        verbose (int): 0=silencieux, 1=barre de progression.

    Returns:
        Tuple[tf.keras.Model, History]: Modèle entraîné + historique d'entraînement.
    """
    callbacks = [
        # Arrêt anticipé si val_loss ne s'améliore plus pendant 15 époques
        EarlyStopping(
            monitor='val_loss',
            patience=15,
            mode='min',
            restore_best_weights=True
        ),
        # Réduction du lr si val_loss stagne pendant 5 époques (lr divisé par 2)
        ReduceLROnPlateau(
            monitor='val_loss',
            factor=0.5,
            patience=5,
            min_lr=1e-6,
            verbose=1
        ),
    ]

    history = model.fit(
        X_train, y_train,
        validation_split=0.3,
        shuffle=False,          # Préserver l'ordre temporel
        batch_size=16,          # Batch plus petit → gradient plus bruité mais plus informatif
        epochs=100,
        callbacks=callbacks,
        verbose=verbose
    )
    return model, history


# ================================================================= #
# 6. VISUALISATION                                                  #
# ================================================================= #

def plot_history(history: tf.keras.callbacks.History):
    """
    Affiche les courbes de perte (MSE) et de métrique (MAE) pour train et validation.

    Affiche également le learning rate au fil des époques pour visualiser les
    réductions appliquées par ReduceLROnPlateau.

    Args:
        history (tf.keras.callbacks.History): Objet History retourné par model.fit().

    Returns:
        np.array: Tableau de trois objets Axes matplotlib.
    """
    fig, ax = plt.subplots(1, 3, figsize=(24, 6))

    # MSE
    ax[0].plot(history.history['loss'], label='Train')
    ax[0].plot(history.history['val_loss'], label='Validation')
    ax[0].set_title('Perte MSE')
    ax[0].set_ylabel('MSE')
    ax[0].set_xlabel('Époque')
    ax[0].legend()
    ax[0].grid(linewidth=0.5)

    # MAE
    ax[1].plot(history.history['mae'], label='Train')
    ax[1].plot(history.history['val_mae'], label='Validation')
    ax[1].set_title('Métrique MAE')
    ax[1].set_ylabel('MAE')
    ax[1].set_xlabel('Époque')
    ax[1].legend()
    ax[1].grid(linewidth=0.5)

    # Learning rate (si disponible)
    if 'lr' in history.history:
        ax[2].plot(history.history['lr'], color='orange', label='Learning Rate')
        ax[2].set_title('Learning Rate')
        ax[2].set_ylabel('LR')
        ax[2].set_xlabel('Époque')
        ax[2].set_yscale('log')
        ax[2].legend()
        ax[2].grid(linewidth=0.5)

    plt.tight_layout()
    return ax


