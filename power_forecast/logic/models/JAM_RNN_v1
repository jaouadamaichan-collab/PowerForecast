def cross_validate_baseline_and_lstm() -> Tuple[List[float], List[float]]:
    """
    Effectue une validation croisée temporelle comparant baseline et LSTM optimisé.

    Pour chaque fold :
        1. Séparation train/test.
        2. Évaluation du baseline naïf.
        3. Entraînement du LSTM optimisé avec early stopping + ReduceLROnPlateau.
        4. Affichage des MAE et du gain relatif.

    Returns:
        Tuple[List[float], List[float]]:
            - list_of_mae_baseline_model  : MAE du baseline pour chaque fold.
            - list_of_mae_recurrent_model : MAE du LSTM pour chaque fold.
    """
    list_of_mae_baseline_model  = []
    list_of_mae_recurrent_model = []

    folds = get_folds(df, FOLD_LENGTH, FOLD_STRIDE)

    for fold_id, fold in enumerate(folds):

        (fold_train, fold_test) = train_test_split(fold, TRAIN_TEST_RATIO, INPUT_LENGTH)
        X_train, y_train = get_X_y_strides(fold_train, INPUT_LENGTH, OUTPUT_LENGTH, SEQUENCE_STRIDE)
        X_test,  y_test  = get_X_y_strides(fold_test,  INPUT_LENGTH, OUTPUT_LENGTH, SEQUENCE_STRIDE)

        # Baseline
        baseline_model = init_baseline()
        mae_baseline   = baseline_model.evaluate(X_test, y_test, verbose=0)[1]
        list_of_mae_baseline_model.append(mae_baseline)

        # LSTM optimisé
        model = init_model(X_train, y_train)
        model, _ = fit_model(model, X_train, y_train, verbose=0)
        mae_lstm = model.evaluate(X_test, y_test, verbose=0)[1]
        list_of_mae_recurrent_model.append(mae_lstm)

        print(f"{'─'*50}")
        print(f"Fold n°{fold_id} | Baseline MAE : {round(mae_baseline, 2)} | LSTM MAE : {round(mae_lstm, 2)}")
        print(f"           🏋🏽 Amélioration : {round((1 - mae_lstm / mae_baseline) * 100, 2)} %")

    print(f"\n{'='*50}")
    print(f"Moyenne Baseline : {round(np.mean(list_of_mae_baseline_model), 2)}")
    print(f"Moyenne LSTM     : {round(np.mean(list_of_mae_recurrent_model), 2)}")
    print(f"🔥 Amélioration moyenne : {round((1 - np.mean(list_of_mae_recurrent_model) / np.mean(list_of_mae_baseline_model)) * 100, 2)} %")

    return list_of_mae_baseline_model, list_of_mae_recurrent_model


mae_baselines, mae_lstms = cross_validate_baseline_and_lstm()
