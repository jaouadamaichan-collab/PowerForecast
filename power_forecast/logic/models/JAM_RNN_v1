# 7. BASELINE NAÏF (inchangé)                                       #
# ================================================================= #

def init_baseline() -> tf.keras.Model:
    """
    Construit le modèle baseline naïf "dernière valeur observée".

    Prédit la valeur TARGET en renvoyant la dernière valeur observée dans X.
    Sert de borne inférieure : le LSTM doit impérativement faire mieux.

    Returns:
        tf.keras.Model: Modèle Keras compilé retournant x[:, -1, 1].
    """
    model = models.Sequential([
        layers.Lambda(lambda x: x[:, -1, 1, None])
    ])
    model.compile(loss='mse', optimizer=optimizers.Adam(learning_rate=0.02), metrics=["mae"])
    return model


